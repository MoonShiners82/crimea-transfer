# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:6543/postgres"

# JWT
JWT_SECRET=your-secret

# Plusofon Flash Call API
PLUSOFON_API_KEY=your-plusofon-access-token
# Public URL for Plusofon webhook callbacks (must be accessible from internet)
PLUSOFON_HOOK_URL=https://your-domain.com/api/auth/plusofon-webhook

# Ollama (optional)
OLLAMA_URL=http://localhost:11434
